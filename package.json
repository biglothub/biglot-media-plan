{
	"name": "biglot-media-plan",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:auto": "node --env-file=.env scripts/dev-auto.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:check": "node scripts/db-check.mjs",
		"db:migrate": "node --env-file=.env scripts/db-migrate.mjs",
		"db:push:auto": "node --env-file=.env scripts/db-migrate.mjs"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.98.0",
		"marked": "^17.0.4",
		"postgres": "^3.4.8"
	}
}
